# ═══════════════════════════════════════════════════════════
# JARVIS — Environment Variable Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to use as reference when setting env vars
# in n8n Settings → Environment Variables.
# ═══════════════════════════════════════════════════════════

# ── TELEGRAM ──────────────────────────────────────────────
# Used by: entry.json, response-sender.json, error-handler.json
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ  # Required. From @BotFather
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here            # Required. Min 20 chars. Used for n8n Telegram Trigger node config
OWNER_USER_ID=123456789                                    # Required. Your Telegram numerical user ID

# ── LLM PROVIDER ──────────────────────────────────────────
# Used by: llm-adapter.json, intent-classifier.json, general-chat.json, memory-store.json
LLM_PROVIDER=groq                                          # Optional. groq|ollama|openai|anthropic (default: groq)
LLM_API_KEY=gsk_your_groq_api_key_here                    # Required. API key for active LLM provider
LLM_API_BASE=https://api.groq.com/openai/v1               # Required. Provider API base URL
LLM_MODEL=llama-3.3-70b-versatile                         # Required. Model name string

# ── LLM PROVIDER: Ollama (if LLM_PROVIDER=ollama) ────────
OLLAMA_API_BASE=http://localhost:11434                     # Optional. (default: http://localhost:11434)
OLLAMA_MODEL=llama3.2:3b                                   # Optional. (default: llama3.2:3b)

# ── LLM PROVIDER: OpenAI (if LLM_PROVIDER=openai) ────────
OPENAI_API_KEY=sk-your_openai_api_key_here                # Optional
OPENAI_API_BASE=https://api.openai.com/v1                 # Optional. (default: https://api.openai.com/v1)
OPENAI_MODEL=gpt-4o-mini                                  # Optional. (default: gpt-4o-mini)

# ── LLM PROVIDER: Anthropic (if LLM_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here      # Optional
ANTHROPIC_MODEL=claude-3-haiku-20240307                    # Optional. (default: claude-3-haiku-20240307)

# ── MEMORY ────────────────────────────────────────────────
# Used by: memory-adapter.json, memory-store.json
MEMORY_PROVIDER=n8n-static                                 # Optional. n8n-static|sqlite (default: n8n-static)
SQLITE_MEMORY_URL=http://localhost:8710                    # Optional. Required if MEMORY_PROVIDER=sqlite
SQLITE_MEMORY_PATH=scripts/jarvis_memory.db                # Optional. SQLite database file path

# ── GOOGLE OAUTH2 ─────────────────────────────────────────
# Used by: google-auth.json, and all Google capability agents
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com # Required. From Google Cloud Console
GOOGLE_CLIENT_SECRET=your_client_secret                    # Required. From Google Cloud Console
GOOGLE_REFRESH_TOKEN=your_refresh_token                    # Required. Obtained via OAuth2 authorization flow
# NOTE: Access tokens are managed automatically by JARVIS — Google Auth workflow.
# Do NOT set GOOGLE_ACCESS_TOKEN or GOOGLE_API_KEY manually.

# ── KNOWLEDGE SOURCES ─────────────────────────────────────
# Used by: knowledge-agent.json
WOLFRAM_ALPHA_APPID=your_wolfram_appid                    # Optional. Required for WolframAlpha queries
SERPAPI_API_KEY=your_serpapi_key                          # Optional. Required for web search fallback

# ── AUDIO / STT ───────────────────────────────────────────
# Used by: input-processor.json
GROQ_API_KEY=gsk_your_groq_api_key_here                   # Optional. Required for voice message transcription via Groq Whisper

# ── ACCESS CONTROL ────────────────────────────────────────
# Used by: entry.json
AUTH_MODE=protected                                        # Optional. open|protected (default: protected)

# ── RATE LIMITING ─────────────────────────────────────────
# Used by: entry.json
RATE_LIMIT_PER_MINUTE=30                                   # Optional. Max requests per user per minute (default: 30)

# ── RESPONSE FORMATTING ───────────────────────────────────
# Used by: response-sender.json
TELEGRAM_MAX_MESSAGE_LENGTH=4000                           # Optional. Telegram message character limit (default: 4000)

# ── LOGGING ───────────────────────────────────────────────
# Used by: All workflows with inline jarvisLog()
LOG_LEVEL=info                                             # Optional. debug|info|warn|error (default: info)

# ── CAPABILITY AGENT ROUTING (optional overrides) ────────
# Used by: capability-router.json
# Set any of these to swap a capability's provider without editing workflows.
# Default values are shown — only set if replacing a provider.
# MAIL_AGENT_NAME=JARVIS — Gmail Agent
# CALENDAR_AGENT_NAME=JARVIS — Calendar Agent
# STORAGE_AGENT_NAME=JARVIS — Drive Agent
# CONTACTS_AGENT_NAME=JARVIS — Contacts Agent
# DOCS_AGENT_NAME=JARVIS — Docs Agent
# SLIDES_AGENT_NAME=JARVIS — Slides Agent
# SHEETS_AGENT_NAME=JARVIS — Sheets Agent
# TASKS_AGENT_NAME=JARVIS — Tasks Agent
# KNOWLEDGE_AGENT_NAME=JARVIS — Knowledge Agent
# CHAT_AGENT_NAME=JARVIS — General Chat
